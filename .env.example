# ── LLM ──────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
# Optional: override model (default: gemini-2.0-flash)
MODEL=gemini-2.0-flash

# ── GitHub (để tạo PR) ───────────────────────────────
GITHUB_TOKEN=ghp_your-token-here
# Format: owner/repo-name
GITHUB_REPO=your-username/your-expo-app

# ── Target Expo project ──────────────────────────────
# Absolute path đến project Expo của bạn
EXPO_PROJECT_DIR=/Users/you/Projects/my-expo-app

# ── Notification webhook (tuỳ chọn) ──────────────────
# POST request khi PR ready (Slack, Discord, custom...)
WEBHOOK_URL=

# ── Web UI ───────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8000
