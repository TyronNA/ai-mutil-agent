# ── GitHub (để tạo PR) ───────────────────────────────
GITHUB_TOKEN=ghp_your-token-here
# Format: owner/repo-name
GITHUB_REPO=your-username/your-game-repo

# ── Target game project ──────────────────────────────
# Absolute path đến project game của bạn
GAME_PROJECT_DIR=/Users/you/Projects/mong-vo-lam

# ── Notification webhook (tuỳ chọn) ──────────────────
# POST request khi PR ready (Slack, Discord, custom...)
WEBHOOK_URL=

# ── LLM model overrides (tuỳ chọn) ──────────────────
# Thay nếu model mặc định không có access
# MODEL=gemini-3-flash-preview
# PRO_MODEL=gemini-3.1-pro-preview
# GCP_LOCATION=us-central1

# (Tuỳ chọn) override giá token dùng cho analytics (USD / 1M tokens)
# Giá điền theo bảng Vertex AI Generative AI Pricing (Gemini 3 Flash Preview + Gemini 3.1 Pro Preview, <=200K input)
FLASH_INPUT_PER_1M=0.50
FLASH_OUTPUT_PER_1M=3.00
FLASH_CACHED_PER_1M=0.05
PRO_INPUT_PER_1M=2.00
PRO_OUTPUT_PER_1M=12.00
PRO_CACHED_PER_1M=0.20

# ── Mate personality evolution ───────────────────────
# Enable native thinking tokens for Flash (512 budget)
# Requires Gemini Flash model with thinking support
# Default: false (PRO always gets 2048 thinking budget)
MATE_FLASH_THINKING=true

# ── Chat compact (auto khi context dài) ─────────────────────────
# Ước lượng token = số ký tự / CHAT_CHARS_PER_TOKEN
# Khi vượt ngưỡng sẽ auto tóm tắt lịch sử và trim bớt turn cũ
CHAT_COMPACT_TOKEN_LIMIT=200000
CHAT_CHARS_PER_TOKEN=4.0
CHAT_COMPACT_KEEP_TURNS=10

# ── Web UI ───────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8000
# Tỷ giá quy đổi hiển thị analytics/sessions (VND trên 1 USD)
NEXT_PUBLIC_VND_RATE=26000

# API key bảo vệ dashboard web (bắt buộc để login)
WEB_API_KEY=replace-with-a-strong-secret
# Thời gian sống cookie login (giây), mặc định 86400 = 24h
WEB_AUTH_TTL_SECONDS=86400
